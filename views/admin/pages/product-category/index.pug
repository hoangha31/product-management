extends ../../layouts/default.pug
include ../../mixins/sort-category.pug
//- include ../../mixins/filterStatus.pug
include ../../mixins/search.pug
block main

   
    h1 Danh mục sản phẩm

    //- div #{records}

    .card.mb-3
        .card-header Bộ lọc và Tìm kiếm
        .card-body
          .row
            .col-6 
                +search(keyword)

    .card.mb-3
        .card-body
            .row
                .col-4
                    a(
                        href=`${prefixAdmin}/products-category/create`
                        class="btn btn-outline-success"
                    ) + Them moi      


    .card.mb-3
        .card-header Sắp xếp
        .card-body
            .row
                .col-4
                    +sortCategory()
    
    .card.mb-3
        .card-header Danh sach 
        .card-body
            
            table(
                class="table table-hover table-sm"
                checkbox-multi
            )
                thead
                    tr
                        th
                            input(type="checkbox" name="checkall")
                        th STT
                        th Hinh anh
                        th Tieu de
                     
                        th Vi tri
                        th Trang thai
                        th Hanh dong

                tbody 
                    each item, index in records
                        tr
                            td
                                input(
                                    type="checkbox"
                                    name="id"
                                    value=item.id
                                )
                            td #{index+1}
                            
                            td 
                                
                                img(
                                    src = item.thumbnail
                                    alt= item.title
                                    width= "100px"
                                    height="auto"
                                )
                            td #{item.title}
                            
                            td 
                                input(
                                    type="number"
                                    value=item.position
                                    style="width: 60px"
                                    min="1"
                                    name="position"
                                )
                            td 
                                if(item.status == "active")
                                    a(
                                        href="javascript:;" 
                                        data-status="active"
                                        data-id= item.id
                                        button-change-status
                                        class="badge badge-success"
                                    ) Hoat dong
                                else
                                    a(
                                        href="javascript:;"
                                        data-status="inactive"
                                        data-id= item.id
                                        button-change-status
                                        class="badge badge-danger"
                                    ) Dung hoat dong
                            td 
                                a(
                                    href= `${prefixAdmin}/products-category/detail/${item.id}`
                                    class="btn btn-secondary btn-sm"
                                    ) Chi tiết
                                a(
                                    href=`${prefixAdmin}/products-category/edit/${item.id}` 
                                    class="btn btn-warning btn-sm") Sua
                                button(
                                    class="btn btn-danger btn-sm ml-1"
                                    button-delete
                                    data-id=item.id
                                ) Xoa




   
    